    "defaultMode": "auto"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "git rev-parse --is-inside-work-tree >/dev/null 2>&1 && git fetch --all --prune >/dev/null 2>&1 || true",
            "timeout": 30,
            "statusMessage": "Fetching latest git refs"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/chuck/.claude/hooks/git-town-steer.sh"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "slack@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "github@claude-plugins-official": true,
    "learning-opportunities-auto@learning-opportunities": true,
    "learning-opportunities@learning-opportunities": true,
    "learning-goal@learning-goal": true,
    "orient@learning-opportunities": true,
    "ruby-lsp@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "learning-opportunities": {
      "source": {
        "source": "git",
        "url": "https://github.com/DrCatHicks/learning-opportunities.git"
      }
    },
    "learning-goal": {
      "source": {
        "source": "git",
        "url": "https://github.com/DrCatHicks/learning-goal.git"
      }
    }
  },
  "skipWebFetchPreflight": true,
  "alwaysThinkingEnabled": true,
  "effortLevel": "medium",
  "skipWorkflowUsageWarning": true,
  "theme": "light",
  "skipAutoPermissionPrompt": true
}
