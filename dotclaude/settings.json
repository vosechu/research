      "Write(**/export_credentials.cfg)",
      "Write(~/.ssh/**)",
      "Write(**/.ssh/**)",
      "Write(~/.aws/**)",
      "Write(**/.aws/**)",
      "Write(~/.kube/**)",
      "Write(**/.kube/**)",
      "Write(~/.docker/**)",
      "WebSearch",
      "WebFetch",
      "Bash(gh repo archive:*)",
      "Bash(GH_HOST=*gh repo archive:*)",
      "Bash(gh repo delete:*)",
      "Bash(GH_HOST=*gh repo delete:*)",
